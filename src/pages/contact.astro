---
import Layout from "../layouts/Layout.astro";
import { links } from "../data/resume";

const contactLinks = links.filter(
  (link) => link.label === "LinkedIn" || link.label === "GitHub",
);
---

<Layout title="Contact — Ryan Fransen-Pruden">
  <header>
    <h1>Contact</h1>
    <p class="subtitle">Open to engineering roles, contracts, and collaboration</p>
  </header>

  <section class="contact-shell">
    <div class="contact-main">
      <div class="section-label">Get started</div>
      <h2 class="section-heading">Best channel: LinkedIn.<br />Fastest response: GitHub + LinkedIn.</h2>
      <p class="intro">
        If you are hiring, building something, or want to talk automation and software
        quality, send me a message. Include scope and timeline for the fastest reply.
      </p>
      <div class="cta-list">
        {contactLinks.map((link) => (
          <a
            href={link.href}
            target="_blank"
            rel="noopener"
            class:list={["cta-item", link.label === "LinkedIn" ? "btn-primary" : "btn-secondary"]}
          >
            <span class="link-icon">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="currentColor"
                set:html={link.icon}
              />
            </span>
            <span>{link.label}</span>
          </a>
        ))}
      </div>
    </div>

    <aside class="profiles-panel">
      <div class="section-label">Profiles</div>
      <div class="link-list">
        {contactLinks.map((link) => (
          <a href={link.href} target="_blank" rel="noopener" class="link-item">
            <span class="link-icon">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="currentColor"
                set:html={link.icon}
              />
            </span>
            <div>
              <div class="link-label">{link.label}</div>
              <div class="link-value">{link.href.replace(/^https?:\/\//, "")}</div>
            </div>
          </a>
        ))}
      </div>
    </aside>
  </section>
</Layout>

<style>
  .section-label {
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--muted-2);
    margin-bottom: 0.75rem;
  }

  .section-label::before {
    content: "// ";
  }

  .contact-shell {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 0;
    align-items: start;
    border: 1px solid var(--border);
  }

  .contact-main {
    background: var(--bg2);
    border-right: 1px solid var(--border);
    padding: 2.5rem;
    animation: fadeUp 0.55s ease forwards;
  }

  .contact-main h2 {
    font-size: clamp(1.6rem, 3vw, 2.4rem);
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 1.2;
    margin-bottom: 0.75rem;
    border-bottom: none;
    padding-bottom: 0;
    text-transform: none;
    color: var(--text);
  }

  .section-heading {
    max-width: 24ch;
  }

  .intro {
    color: var(--muted);
    font-size: 0.9rem;
    line-height: 1.65;
    font-family: var(--font);
    font-weight: 300;
    max-width: 52ch;
  }

  .cta-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1.5rem;
  }

  .cta-item {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    padding: 0.75rem 1.75rem;
    font-family: var(--mono);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    border: 1px solid var(--border-bright);
    transition: all 0.2s;
  }

  .btn-primary {
    background: var(--accent);
    color: #000;
    border-color: var(--accent);
  }

  .btn-primary:hover {
    background: #ffffff;
    border-color: #ffffff;
    color: #000000;
    transform: translateY(-1px);
  }

  .btn-secondary {
    background: transparent;
    color: var(--text);
    border-color: var(--border-bright);
  }

  .btn-secondary:hover {
    color: var(--text);
    border-color: var(--text);
  }

  .cta-item .link-icon {
    color: currentColor;
  }

  .profiles-panel {
    background: var(--bg);
    padding: 2.5rem 1.5rem;
    animation: fadeUp 0.55s ease forwards 0.1s;
    opacity: 0;
  }

  .link-list {
    display: flex;
    flex-direction: column;
    gap: 0;
    margin-top: 1rem;
    border: 1px solid var(--border);
  }

  .link-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: var(--text);
    padding: 0.9rem 0.75rem;
    border-bottom: 1px solid var(--border);
    transition: border-color 0.15s, color 0.15s;
  }

  .link-item:last-child {
    border-bottom: none;
  }

  .link-item:hover {
    color: var(--accent);
    background: color-mix(in srgb, var(--bg2) 50%, transparent);
  }

  .link-icon {
    color: var(--muted);
    display: flex;
    align-items: center;
  }

  .link-label {
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .link-value {
    font-size: 0.72rem;
    color: var(--muted);
    font-family: var(--mono);
    margin-top: 0.2rem;
    word-break: break-word;
  }

  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(14px);
    }

    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 900px) {
    .contact-shell {
      grid-template-columns: 1fr;
    }

    .contact-main {
      border-right: none;
      border-bottom: 1px solid var(--border);
      padding: 2rem 1.25rem;
    }

    .profiles-panel {
      padding: 2rem 1.25rem;
    }
  }
</style>
