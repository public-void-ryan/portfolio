---
import Layout from "../layouts/Layout.astro";
import { links } from "../data/resume";

const contactLinks = links.filter(
  (link) => link.label === "LinkedIn" || link.label === "GitHub",
);
---

<Layout title="Contact — Ryan Fransen-Pruden">
  <header>
    <h1>Contact</h1>
    <p class="subtitle">Got a project in mind or just want to connect?</p>
  </header>

  <div class="contact-grid">
    <section class="primary-section">
      <h2>Reach Out</h2>
      <p class="intro">
        Best way to connect is through LinkedIn or GitHub. If you are interested in
        working together, send me a message on LinkedIn.
      </p>
      <div class="cta-list">
        {contactLinks.map((link) => (
          <a href={link.href} target="_blank" rel="noopener" class="cta-item">
            <span class="link-icon">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="currentColor"
                set:html={link.icon}
              />
            </span>
            <span>{link.label}</span>
          </a>
        ))}
      </div>
    </section>

    <section class="links-section">
      <h2>Profiles</h2>
      <div class="link-list">
        {contactLinks.map((link) => (
          <a href={link.href} target="_blank" rel="noopener" class="link-item">
            <span class="link-icon">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="currentColor"
                set:html={link.icon}
              />
            </span>
            <div>
              <div class="link-label">{link.label}</div>
              <div class="link-value">{link.href.replace(/^https?:\/\//, "")}</div>
            </div>
          </a>
        ))}
      </div>
    </section>
  </div>
</Layout>

<style>
  .subtitle {
    color: var(--muted);
    font-size: 0.95rem;
    margin-top: 0.5rem;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: 2rem;
    align-items: start;
  }

  .primary-section {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1.75rem;
  }

  .primary-section h2 {
    margin-bottom: 1rem;
  }

  .intro {
    color: var(--muted);
    font-size: 0.92rem;
    line-height: 1.55;
  }

  .cta-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-top: 1.25rem;
  }

  .cta-item {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    border: 1px solid var(--border);
    border-radius: 6px;
    color: var(--text);
    background: color-mix(in srgb, var(--bg) 60%, transparent);
    padding: 0.65rem 0.75rem;
    font-weight: 600;
    transition: border-color 0.15s, color 0.15s;
  }

  .cta-item:hover {
    border-color: var(--accent);
    color: var(--accent);
    text-decoration: none;
  }

  .links-section {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1.25rem;
  }

  .link-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-top: 1rem;
  }

  .link-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: var(--text);
    padding: 0.6rem 0.75rem;
    border-radius: 6px;
    border: 1px solid var(--border);
    transition: border-color 0.15s, color 0.15s;
  }

  .link-item:hover {
    border-color: var(--accent);
    color: var(--accent);
    text-decoration: none;
  }

  .link-icon {
    color: var(--muted);
    display: flex;
    align-items: center;
  }

  .link-label {
    font-size: 0.8rem;
    font-weight: 600;
  }

  .link-value {
    font-size: 0.8rem;
    color: var(--muted);
    font-family: var(--mono);
  }

  @media (max-width: 700px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
