---
import Layout from "../layouts/Layout.astro";

const projects = [
  {
    title: "Project One",
    description: "A short description of what this project does and the problem it solves.",
    tags: ["C#", "Docker"],
    github: "https://github.com/public-void-ryan",
    demo: null,
  },
  {
    title: "Project Two",
    description: "A short description of what this project does and the problem it solves.",
    tags: ["Python", "SQL"],
    github: "https://github.com/public-void-ryan",
    demo: null,
  },
  {
    title: "Personal Portfolio",
    description: "This site — a resume and project portfolio built with Astro. Statically generated, no frameworks, deployed via Forgejo Actions.",
    tags: ["Astro", "TypeScript", "NixOS"],
    github: "https://github.com/public-void-ryan",
    demo: "https://ryanfp.dev",
    thumbnail: "/thumbnails/portfolio.gif",
  },
  {
    title: "PEAK Health Nepal",
    description: "Website and social media presence for a nonprofit providing ICU nurse training in Nepal. Features a resource library, donation integration, and admin tooling.",
    tags: ["React", "Node.js", "PostgreSQL", "Stripe"],
    github: null,
    demo: "https://peakhealthnepal.org/",
    thumbnail: "/thumbnails/peak.webp",
  },
];
---

<Layout title="Portfolio — Ryan Fransen-Pruden">
  <header>
    <h1>Portfolio</h1>
    <p class="subtitle">Selected projects and production work</p>
  </header>

  <section>
    <div class="section-label">Projects</div>
    <h2 class="section-heading">Shipped work across web, tooling, and automation.</h2>
    <div class="projects-grid">
      {projects.map((p) => (
        <div class="card">
          {p.thumbnail && (
            <img class="card-thumb" src={p.thumbnail} alt={p.title} loading="lazy" />
          )}
          <div class="card-body">
            <h3>{p.title}</h3>
            <p>{p.description}</p>
            <div class="tags">
              {p.tags.map((t) => <span class="tag">{t}</span>)}
            </div>
          </div>
          <div class="card-links">
            {p.github && <a href={p.github} target="_blank" rel="noopener">GitHub</a>}
            {p.demo && <a href={p.demo} target="_blank" rel="noopener">Live</a>}
          </div>
        </div>
      ))}
    </div>
  </section>
</Layout>

<style>
  .section-label {
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--muted-2);
    margin-bottom: 0.75rem;
  }

  .section-label::before {
    content: "// ";
  }

  .section-heading {
    font-size: clamp(1.6rem, 3vw, 2.4rem);
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 1.2;
    margin-bottom: 3rem;
    text-transform: none;
    color: var(--text);
    border-bottom: none;
    padding-bottom: 0;
    font-family: var(--mono);
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0;
    border: 1px solid var(--border);
  }

  .card-thumb {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    border-bottom: 1px solid var(--border);
  }

  .card {
    background: var(--bg2);
    border-right: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    padding: 2rem;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 1.25rem;
    opacity: 0;
    animation: fadeUp 0.5s ease forwards;
  }

  .card:nth-child(1) {
    animation-delay: 0.08s;
  }

  .card:nth-child(2) {
    animation-delay: 0.16s;
    border-right: none;
  }

  .card:nth-child(3) {
    animation-delay: 0.24s;
    border-bottom: none;
  }

  .card:nth-child(4) {
    animation-delay: 0.32s;
    border-right: none;
    border-bottom: none;
  }

  .card-body {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .card-body h3 {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--text);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .card-body p {
    font-family: var(--font);
    font-size: 0.82rem;
    color: var(--muted);
    line-height: 1.6;
    font-weight: 300;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin-top: 0.5rem;
  }

  .tag {
    background: var(--accent-soft);
    border: 1px solid var(--border);
    color: var(--accent);
    font-size: 0.65rem;
    padding: 0.22rem 0.56rem;
    font-family: var(--mono);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .card-links {
    display: flex;
    gap: 0.65rem;
    flex-wrap: wrap;
  }

  .card-links a {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    background: transparent;
    color: var(--muted);
    padding: 0.58rem 0.95rem;
    font-family: var(--mono);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    border: 1px solid var(--border-bright);
    transition: all 0.2s;
  }

  .card-links a::before {
    content: "→";
    color: var(--accent);
  }

  .card-links a:hover {
    color: var(--text);
    border-color: var(--text);
  }

  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(14px);
    }

    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 900px) {
    .projects-grid {
      grid-template-columns: 1fr;
    }

    .card {
      border-right: none;
      border-bottom: 1px solid var(--border);
    }

    .card:nth-child(3),
    .card:nth-child(4) {
      border-bottom: 1px solid var(--border);
    }

    .card:last-child {
      border-bottom: none;
    }
  }
</style>
