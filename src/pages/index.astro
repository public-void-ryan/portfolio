---
const name = "Ryan Fransen-Pruden";
const title = "Software Engineer";
const github = "github.com/public-void-ryan";
const linkedin = "linkedin.com/in/ryan-fransen-pruden";
const site = "ryanfp.dev";

const skills = {
  "Languages": ["C#", ".NET", "Python", "C++", "JavaScript", "SQL", "R", "HTML/CSS", "LaTeX", "Nix"],
  "Protocols & APIs": ["REST", "JSON", "SOAP", "XML"],
  "Tools": ["SQL Server", "Visual Studio", "Selenium", "Docker", "Git", "Jira", "BitBucket", "Vim", "NixOS", "nginx", "SSH", "bash", "zsh"],
  "Linux": ["NixOS", "Arch", "Debian", "System Administration", "Networking"],
};

const experience = [
  {
    company: "eMoney Advisor",
    location: "Radnor, PA (Remote)",
    roles: [
      {
        title: "QA Automation Engineer",
        period: "Jan 2025 – Present",
        bullets: [
          "Build and maintain automated test suites using Selenium and C#.",
          "Improve test coverage and reduce regression cycle time.",
          "Collaborate with dev and product teams to define acceptance criteria.",
        ],
      },
      {
        title: "Technical Support Analyst",
        period: "Jun 2022 – Jan 2025",
        bullets: [
          "Used SQL queries to validate customer data and diagnose issues.",
          "Reviewed code specifications to validate system design or escalate defects.",
          "Liaised between Client Services and QA, Development, and Operations.",
          "Served as primary point of contact for technical queries across departments.",
        ],
      },
      {
        title: "Data Support Analyst",
        period: "Sep 2021 – Jun 2022",
        bullets: [
          "Provided Tier-2 support via chat, email, and phone.",
          "Interpreted HTTP responses including JSON, XML, and HTML.",
          "Collaborated with end-users and internal teams to resolve technical issues.",
        ],
      },
      {
        title: "AI Data Labeler",
        period: "Jun 2021 – Aug 2021",
        bullets: [
          "Labeled training data for ML models in Amazon SageMaker.",
          "Ensured data quality and improved model accuracy via performance metrics.",
        ],
      },
    ],
  },
  {
    company: "Menard Inc.",
    location: "Golden Valley, MN",
    roles: [
      {
        title: "Yard and Receiving Manager",
        period: "Oct 2013 – Feb 2021",
        bullets: [
          "Managed a team of 30+ in receiving operations; improved freight handling by 40%.",
          "Supported the busiest Menards location in Minnesota.",
          "Resolved vendor issues and ensured alignment with financial targets.",
        ],
      },
    ],
  },
];

const education = [
  {
    degree: "B.S. Software Engineering",
    school: "St. Cloud State University",
    date: "May 2026",
  },
  {
    degree: "A.A.S. Database Administration",
    school: "Minnesota Community & Technical College",
    date: "May 2022",
  },
];

const certs = [
  { name: "TestOut Network Pro", date: "Dec 2023" },
  { name: "Google Data Analytics Professional Certificate", date: "Mar 2022" },
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Portfolio and resume of Ryan Fransen-Pruden, Software Engineer." />
    <title>{name}</title>
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      :root {
        --bg: #0f1117;
        --surface: #1a1d27;
        --border: #2a2d3a;
        --accent: #7aa2f7;
        --accent2: #9ece6a;
        --text: #c0caf5;
        --muted: #565f89;
        --heading: #e0e4f5;
        --font: 'Segoe UI', system-ui, sans-serif;
        --mono: 'JetBrains Mono', 'Fira Code', monospace;
      }

      html { font-size: 16px; scroll-behavior: smooth; }

      body {
        background: var(--bg);
        color: var(--text);
        font-family: var(--font);
        line-height: 1.6;
        min-height: 100vh;
      }

      a { color: var(--accent); text-decoration: none; }
      a:hover { text-decoration: underline; }

      .container {
        max-width: 860px;
        margin: 0 auto;
        padding: 2rem 1.5rem 4rem;
      }

      header {
        border-bottom: 1px solid var(--border);
        padding-bottom: 2rem;
        margin-bottom: 2.5rem;
      }

      header h1 {
        font-size: 2.2rem;
        font-weight: 700;
        color: var(--heading);
        letter-spacing: -0.02em;
      }

      .subtitle {
        font-size: 1rem;
        color: var(--accent);
        margin-top: 0.25rem;
        font-family: var(--mono);
      }

      .links {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
        margin-top: 1rem;
      }

      .links a {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        color: var(--muted);
        font-size: 0.85rem;
        padding: 0.3rem 0.75rem;
        border: 1px solid var(--border);
        border-radius: 6px;
        background: var(--surface);
        transition: color 0.15s, border-color 0.15s;
      }

      .links a:hover {
        color: var(--accent);
        border-color: var(--accent);
        text-decoration: none;
      }

      .links a svg { flex-shrink: 0; }

      section { margin-bottom: 2.5rem; }

      h2 {
        font-size: 0.75rem;
        font-weight: 600;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--accent2);
        font-family: var(--mono);
        margin-bottom: 1.25rem;
        padding-bottom: 0.5rem;
        border-bottom: 1px solid var(--border);
      }

      .skills-grid { display: flex; flex-direction: column; gap: 0.75rem; }

      .skill-row {
        display: grid;
        grid-template-columns: 160px 1fr;
        gap: 0.75rem;
        align-items: start;
      }

      .skill-label { font-size: 0.8rem; color: var(--muted); padding-top: 0.2rem; }

      .skill-tags { display: flex; flex-wrap: wrap; gap: 0.4rem; }

      .tag {
        background: var(--surface);
        border: 1px solid var(--border);
        color: var(--text);
        font-size: 0.8rem;
        padding: 0.15rem 0.6rem;
        border-radius: 4px;
        font-family: var(--mono);
      }

      .company-block { margin-bottom: 2rem; }

      .company-header {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        flex-wrap: wrap;
        gap: 0.5rem;
        margin-bottom: 1rem;
      }

      .company-name { font-weight: 600; color: var(--heading); font-size: 1rem; }
      .company-location { font-size: 0.8rem; color: var(--muted); }

      .role {
        margin-bottom: 1.25rem;
        padding-left: 1rem;
        border-left: 2px solid var(--border);
      }

      .role-header {
        display: flex;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 0.25rem;
        margin-bottom: 0.5rem;
      }

      .role-title { font-weight: 500; color: var(--text); font-size: 0.95rem; }
      .role-period { font-size: 0.8rem; color: var(--muted); font-family: var(--mono); }

      ul { list-style: none; display: flex; flex-direction: column; gap: 0.3rem; }

      li {
        font-size: 0.9rem;
        color: var(--text);
        padding-left: 1rem;
        position: relative;
      }

      li::before { content: '–'; position: absolute; left: 0; color: var(--muted); }

      .edu-grid { display: flex; flex-direction: column; gap: 0.75rem; }

      .edu-row {
        display: flex;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 0.25rem;
      }

      .edu-degree { font-weight: 500; color: var(--heading); font-size: 0.95rem; }
      .edu-school { font-size: 0.85rem; color: var(--muted); }
      .edu-date { font-size: 0.8rem; color: var(--muted); font-family: var(--mono); white-space: nowrap; }
      .cert { color: var(--text); font-size: 0.9rem; }

      footer {
        margin-top: 3rem;
        padding-top: 1.5rem;
        border-top: 1px solid var(--border);
        font-size: 0.8rem;
        color: var(--muted);
        text-align: center;
      }

      @media (max-width: 600px) {
        header h1 { font-size: 1.6rem; }
        .skill-row { grid-template-columns: 1fr; }
      }
    </style>
  </head>
  <body>
    <div class="container">
      <header>
        <h1>{name}</h1>
        <div class="subtitle">{title}</div>
        <div class="links">
          <a href={`https://${github}`} target="_blank" rel="noopener">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"/></svg>
            GitHub
          </a>
          <a href={`https://${linkedin}`} target="_blank" rel="noopener">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            LinkedIn
          </a>
        </div>
      </header>

      <section>
        <h2>Skills</h2>
        <div class="skills-grid">
          {Object.entries(skills).map(([label, tags]) => (
            <div class="skill-row">
              <span class="skill-label">{label}</span>
              <div class="skill-tags">
                {tags.map(t => <span class="tag">{t}</span>)}
              </div>
            </div>
          ))}
        </div>
      </section>

      <section>
        <h2>Experience</h2>
        {experience.map(co => (
          <div class="company-block">
            <div class="company-header">
              <span class="company-name">{co.company}</span>
              <span class="company-location">{co.location}</span>
            </div>
            {co.roles.map(role => (
              <div class="role">
                <div class="role-header">
                  <span class="role-title">{role.title}</span>
                  <span class="role-period">{role.period}</span>
                </div>
                <ul>
                  {role.bullets.map(b => <li>{b}</li>)}
                </ul>
              </div>
            ))}
          </div>
        ))}
      </section>

      <section>
        <h2>Education</h2>
        <div class="edu-grid">
          {education.map(e => (
            <div class="edu-row">
              <div>
                <div class="edu-degree">{e.degree}</div>
                <div class="edu-school">{e.school}</div>
              </div>
              <span class="edu-date">{e.date}</span>
            </div>
          ))}
          {certs.map(c => (
            <div class="edu-row">
              <span class="cert">{c.name}</span>
              <span class="edu-date">{c.date}</span>
            </div>
          ))}
        </div>
      </section>

      <footer>
		&copy; {new Date().getFullYear()} {name}. All rights reserved.
      </footer>
    </div>
  </body>
</html>
