---
interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "Portfolio and resume of Ryan Fransen-Pruden, Software Engineer.",
} = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@300;400;500;600&family=IBM+Plex+Sans:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    <style is:global>
      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      :root {
        --bg: #0a0a0a;
        --bg2: #111111;
        --surface: #1a1a1a;
        --border: #2a2a2a;
        --border-bright: #3a3a3a;
        --accent: #00d084;
        --accent-soft: #00d08422;
        --text: #e8e8e8;
        --muted: #888888;
        --muted-2: #555555;
        --heading: #f2f2f2;
        --font: "IBM Plex Sans", sans-serif;
        --mono: "IBM Plex Mono", monospace;
      }

      html {
        font-size: 16px;
        scroll-behavior: smooth;
      }

      body {
        background: var(--bg);
        color: var(--text);
        font-family: var(--mono);
        line-height: 1.6;
        min-height: 100vh;
        overflow-x: hidden;
      }

      body::before {
        content: "";
        position: fixed;
        inset: 0;
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
        pointer-events: none;
        z-index: 9999;
        opacity: 0.5;
      }

      body::after {
        content: "";
        position: fixed;
        inset: 0;
        background: repeating-linear-gradient(
          0deg,
          transparent,
          transparent 2px,
          rgba(0, 0, 0, 0.03) 2px,
          rgba(0, 0, 0, 0.03) 4px
        );
        pointer-events: none;
        z-index: 9998;
      }

      a {
        color: var(--accent);
        text-decoration: none;
      }
      a:hover {
        text-decoration: none;
      }

      nav {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 100;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1rem 2rem;
        border-bottom: 1px solid var(--border);
        background: rgba(10, 10, 10, 0.92);
        backdrop-filter: blur(12px);
      }

      .nav-home {
        font-family: var(--mono);
        font-weight: 500;
        font-size: 0.8rem;
        color: var(--accent);
        letter-spacing: 0.15em;
        text-transform: uppercase;
      }

      .nav-links {
        display: flex;
        gap: 1.5rem;
      }

      .nav-links a {
        font-size: 0.75rem;
        color: var(--muted);
        letter-spacing: 0.08em;
        text-transform: uppercase;
        transition: color 0.2s;
      }

      .nav-links a:hover {
        color: var(--text);
      }

      .container {
        max-width: 980px;
        margin: 0 auto;
        padding: 6.5rem 2rem 4rem;
        position: relative;
        z-index: 1;
      }

      header {
        margin-bottom: 2.5rem;
        border-bottom: 1px solid var(--border);
        padding-bottom: 1.5rem;
      }

      header h1 {
        font-size: 2.2rem;
        font-weight: 500;
        color: var(--heading);
        letter-spacing: -0.02em;
      }

      .subtitle {
        font-size: 0.85rem;
        color: var(--accent);
        margin-top: 0.5rem;
        font-family: var(--mono);
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      .links {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
        margin-top: 1.25rem;
      }

      .links a {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        color: var(--text);
        font-size: 0.78rem;
        padding: 0.42rem 0.8rem;
        border: 1px solid var(--border);
        border-radius: 0;
        background: color-mix(in srgb, var(--bg2) 84%, transparent);
        transition: color 0.15s, border-color 0.15s;
        letter-spacing: 0.06em;
        text-transform: uppercase;
      }

      .links a:hover {
        color: var(--accent);
        border-color: var(--accent);
      }

      .links a svg {
        flex-shrink: 0;
      }

      section {
        margin-bottom: 2.5rem;
      }

      h2 {
        font-size: 0.72rem;
        font-weight: 500;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--muted);
        font-family: var(--mono);
        margin-bottom: 1.25rem;
        padding-bottom: 0.5rem;
        border-bottom: 1px solid var(--border);
      }

      .card,
      .form-section,
      .links-section,
      .primary-section,
      .tag {
        border-radius: 0 !important;
      }

      footer {
        margin-top: 3rem;
        padding-top: 1.5rem;
        border-top: 1px solid var(--border);
        font-size: 0.72rem;
        color: var(--muted);
        text-align: center;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      @media (max-width: 700px) {
        nav {
          padding: 0.85rem 1rem;
        }

        .nav-links {
          gap: 0.85rem;
        }

        .nav-links a {
          font-size: 0.68rem;
          letter-spacing: 0.05em;
        }

        header h1 {
          font-size: 1.6rem;
        }

        .container {
          padding: 5.5rem 1rem 3rem;
        }
      }
    </style>
  </head>
  <body>
    <nav>
      <a href="/" class="nav-home">Home</a>
      <div class="nav-links">
        <a href="/portfolio">Portfolio</a>
        <a href="/contact">Contact</a>
      </div>
    </nav>
    <div class="container">
      <slot />
      <footer>
        &copy; {new Date().getFullYear()}
        {title}
      </footer>
    </div>
  </body>
</html>
